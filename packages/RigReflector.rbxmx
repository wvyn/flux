<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="ModuleScript" referent="RBXC23E8A2272C74F67AA367219388A4B27">
		<Properties>
			<Content name="LinkedSource"><null></null></Content>
			<ProtectedString name="Source"><![CDATA[local reflectionService = game:GetService("ReflectionService")

local RigReflector = {}
local RigReflectorMethods = {}

local propertyCache = {}

function RigReflector.new(character: Instance, sourceRig: Instance, ignore: { Properties: { string }?, Classes: { string }? }?)
	local reflector = setmetatable({}, { __index = RigReflectorMethods })

	reflector.Character = character
	reflector.Rig = sourceRig
	
	reflector.Ignore = ignore or {
		Properties = {} :: { string }?,
		Classes = {} :: { string }?
	}
	
	reflector.Ignore.Properties = reflector.Ignore.Properties or {}
	reflector.Classes.Properties = reflector.Classes.Properties or {}

	reflector._connections = {}
	reflector._propertyConnections = {}

	return reflector
end

function RigReflectorMethods.Destroy(self: RigReflector)
	for _, connection in next, self._connections do
		connection:Disconnect()
	end

	for _, connection in next, self._propertyConnections do
		connection:Disconnect()
	end
	
	for i in next, self do
		self[i] = nil
	end

	setmetatable(self, {})
end

function RigReflectorMethods.Start(self: RigReflector)
	for _, descendant in next, self.Character:GetDescendants() do
		task.spawn(self._addAsset, self, descendant)
	end

	self._connections[#self._connections + 1] = self.Character.DescendantAdded:Connect(function(descendant)
		self:_addAsset(descendant)
	end)


	self._connections[#self._connections + 1] = self.Character.DescendantRemoving:Connect(function(descendant)
		self:_removeAsset(descendant)
	end)

	self._connections[#self._connections + 1] = self.Rig.Destroying:Connect(function()
		self:Destroy()
	end)

	self._connections[#self._connections + 1] = self.Character.Destroying:Connect(function()
		self:Destroy()
	end)

	self._connections[#self._connections + 1] = self.Character:GetPropertyChangedSignal("Parent"):Connect(function()
		if not self.Character.Parent then
			self:Destroy()
		end
	end)

	self._connections[#self._connections + 1] = self.Rig:GetPropertyChangedSignal("Parent"):Connect(function()
		if not self.Rig.Parent then
			self:Destroy()
		end
	end)
end

function RigReflectorMethods._getProperties(self: RigReflector, className: string): ReflectedProperties
	local cached = propertyCache[className]
	if cached ~= nil then
		return cached
	end

	local props = reflectionService:GetPropertiesOfClass(className)
	propertyCache[className] = props

	return props
end

function RigReflectorMethods._getRigEquivalent(self: RigReflector, sourcePart: Instance, yield: number?)
	local parentPath = { sourcePart }
	local parentLocation = sourcePart

	repeat
		if parentLocation == self.Character or not parentLocation then
			break
		end

		parentPath[#parentPath + 1] = parentLocation.Parent
		parentLocation = parentLocation.Parent
	until parentLocation == self.Character or parentLocation == game

	if #parentPath == 1 and self.Rig:FindFirstChild(sourcePart.Name) then
		parentPath[#parentPath + 1] = self.Character
	end

	if parentPath[#parentPath] == self.Character then
		local rigParent = self.Rig

		for i = #parentPath - 1, 1, -1 do
			if not rigParent then break end
			if yield then
				rigParent = rigParent:WaitForChild(parentPath[i].Name, yield)
			else
				rigParent = rigParent:FindFirstChild(parentPath[i].Name)
			end
		end

		return rigParent
	end
end

function RigReflectorMethods._syncProperty(self: RigReflector, source: Instance, rigInstance: Instance, propertyName: string)
	local value = source[propertyName]
	if typeof(value) == "function" then return end
	if propertyName == "Capabilities" then return end
	if propertyName == "Sandboxed" then return end
	
	for _, ignoreProperty in next, self.Ignore.Properties do
		if ignoreProperty == propertyName then return end
	end

	if typeof(value) == "Instance" and value:IsDescendantOf(self.Character) then
		value = self:_getRigEquivalent(value, 3)
	end

	rigInstance[propertyName] = value
end

function RigReflectorMethods._connectProperty(self: RigReflector, source: Instance, rigInstance: Instance, propertyName: string)
	local connection
	connection = source:GetPropertyChangedSignal(propertyName):Connect(function()
		self:_syncProperty(source, rigInstance, propertyName)
	end)

	table.insert(self._propertyConnections, connection)
end

function RigReflectorMethods._addAsset(self: RigReflector, asset: Instance)
	if asset:IsA("Status") then return end
	
	for _, class in next, self.Ignore.Classes do
		if asset:IsA(class) then return end
	end

	local parentPath = {}
	local parentLocation = asset

	repeat
		if not parentLocation then break end
		parentPath[#parentPath + 1] = parentLocation.Parent
		parentLocation = parentLocation.Parent
	until parentLocation == self.Character or parentLocation == game

	if parentPath[#parentPath] ~= self.Character then
		return
	end

	local rigParent = self.Rig
	for i = #parentPath - 1, 1, -1 do
		if not rigParent then break end
		rigParent = rigParent:FindFirstChild(parentPath[i].Name)
	end

	if not rigParent then return end

	local copy = rigParent:FindFirstChild(asset.Name)
	if not copy then
		copy = Instance.fromExisting(asset)
	end

	local reflectionProperties = self:_getProperties(asset.ClassName)
	if reflectionProperties then
		for _, reflectionProperty in next, reflectionProperties do
			task.spawn(function()
				if not (reflectionProperty.Permits.Write and reflectionProperty.Permits.Read) then
					return
				end

				if reflectionProperty.Display and reflectionProperty.Display.DeprecationMessage then
					return
				end

				self:_syncProperty(asset, copy, reflectionProperty.Name)
				self:_connectProperty(asset, copy, reflectionProperty.Name)
			end)
		end
	end
	
	copy.Parent = rigParent
end

function RigReflectorMethods._removeAsset(self: RigReflector, asset: Instance)
	local instance = self:_getRigEquivalent(asset)
	if instance then
		instance:Destroy()
	end
end

export type RigReflector = typeof(RigReflector.new(nil :: any, nil :: any))

return RigReflector]]></ProtectedString>
			<string name="ScriptGuid">{15F4C90E-973C-4EF7-BF00-BA11811B862E}</string>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">RigReflector</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
	</Item>
</roblox>
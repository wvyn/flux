			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">RigReflector</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
	</Item>
</roblox>
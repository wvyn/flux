<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="ModuleScript" referent="RBXADE27CCB544C4AF4BADA9C643B814B9E">
		<Properties>
			<Content name="LinkedSource"><null></null></Content>
			<ProtectedString name="Source"><![CDATA[--[[
Wyverion 2026 (cc)
]]

const FormData = {}
const FormDataMethods = {}

function FormData.new(title: string?)
	return setmetatable({
		Boundary = `----{title or "FormData"..math.random(100000, 999999)}`,
		Parts = {}
	}, { __index = FormDataMethods })
end

function FormDataMethods.AppendField(self: FormData, name: string, value: string)
	local field = {
		type = "field",
		name = name,
		value = tostring(value)
	}
	
	self.Parts[#self.Parts + 1] = field
	return field
end

function FormDataMethods.AppendFile(self: FormData, name: string, filename: string, content: string, contentType: string?)
	local field = {
		type = "file",
		name = name,
		filename = filename,
		content = content,
		contentType = contentType or "application/octet-stream"
	}
	
	self.Parts[#self.Parts + 1] = field
	return field
end

function FormDataMethods.GetContentType(self: FormData)
	return `multipart/form-data; boundary={self.Boundary}`
end

function FormDataMethods.Build(self: FormData)
	local body = {}

	for i = 1, #self.Parts do
		body[#body + 1] = `--{self.Boundary}\r\n`
		
		local part = self.Parts[i]
		if part.type == "field" then
			body[#body + 1] = `Content-Disposition: form-data; name="{part.name}"\r\n\r\n{part.value}\r\n`
		else
			body[#body + 1] = `Content-Disposition: form-data; name="{part.name}"; filename="{part.filename}"\r\n`
			body[#body + 1] = `Content-Type: {part.contentType or "application/octet-stream"}\r\n\r\n`
			body[#body + 1] = part.content
			body[#body + 1] = "\r\n"
		end
	end

	body[#body + 1] = "--" .. self.Boundary .. "--\r\n"

	return table.concat(body)
end

export type FormData = typeof(FormData.new())

return FormData]]></ProtectedString>
			<string name="ScriptGuid">{61754C8A-36A8-42E6-A9FC-E071637016EC}</string>

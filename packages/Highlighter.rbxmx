<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="ModuleScript" referent="RBX4A720DBBE9154CC8A16DC325FBDA21D6">
		<Properties>
			<Content name="LinkedSource"><null></null></Content>
			<ProtectedString name="Source"><![CDATA[local highlighter = {}
local keywords = {
	lua = {
		"and","break","do","else","elseif","end","for","function","if","in",
		"local","not","or","repeat","return","then","until","while",

		"continue","export","type","typeof",
	},

	rbx = {
		"_G","_VERSION","game","Game","workspace","Workspace","shared",

		"assert","collectgarbage","error","gcinfo","getfenv","setfenv",
		"getmetatable","setmetatable",
		"ipairs","pairs","next",
		"pcall","xpcall","ypcall",
		"print","warn","printidentity",
		"rawequal","rawget","rawset","rawlen",
		"select","tonumber","tostring","type","typeof","unpack",
		"require","loadstring","newproxy",

		"wait","Wait","spawn","Spawn","delay","Delay",
		"tick","time","elapsedTime","ElapsedTime",

		"UserSettings","settings","Stats","stats","Version","version",
	},
	
	rbxclass = {
		"Wyverion", "Process",
		
		"Instance","Enum",

		"math","string","table","utf8","os","coroutine","debug","bit32","task",

		"CFrame","Vector2","Vector3","Vector2int16","Vector3int16",
		"UDim","UDim2","Ray","Region3","Region3int16","Rect",
		"Axes","Faces",
		"Color3","BrickColor",
		"NumberRange","NumberSequence","NumberSequenceKeypoint",
		"ColorSequence","ColorSequenceKeypoint",
		"PhysicalProperties","TweenInfo","Random",
		"RaycastParams","OverlapParams",
		"DockWidgetPluginGuiInfo","PathWaypoint",
		"DateTime","CatalogSearchParams","Font",
		"RotationCurveKey","FloatCurveKey",
		"SharedTable","buffer"
	},

	operators = {
		"#","+","-","*","%","/","^",
		"=","==","~=","<",">","<=",">=",
		"(",")","{","}","[","]",
		";",":",",",".","..","...",
	}
}

local colors = {
	numbers = Color3.fromRGB(255, 198, 0),
	boolean = Color3.fromRGB(255, 198, 0),
	operator = Color3.fromRGB(232, 210, 40),
	rbx = Color3.fromRGB(132, 214, 247),
	lua = Color3.fromRGB(248, 109, 124),
	str = Color3.fromRGB(56, 241, 87),
	comment = Color3.fromRGB(102, 102, 102),
	null = Color3.fromRGB(255, 198, 0),
	call = Color3.fromRGB(253, 251, 172),
	self_call = Color3.fromRGB(253, 251, 172),
	local_color = Color3.fromRGB(248, 109, 124),
	function_color = Color3.fromRGB(248, 109, 124),
	self_color = Color3.fromRGB(248, 109, 124),
	local_property = Color3.fromRGB(97, 161, 241),
	type_annotation = Color3.fromRGB(97, 161, 241),
}

local function createSet(list: { any })
	local set = {}
	for i = 1, #list do
		set[list[i]] = true
	end
	return set
end

local luaSet = createSet(keywords.lua)
local rbxSet = createSet(keywords.rbx)
local rbxclassSet = createSet(keywords.rbxclass)
local operatorsSet = createSet(keywords.operators)

local function tokenize(source: string)
	local tokens = {}
	local i = 1

	while i <= #source do
		local c = source:sub(i, i)

		-- whitespace
		if c:match("%s") then
			tokens[#tokens + 1] = c
			i += 1

			-- vararg
		elseif source:sub(i, i+2) == "..." then
			tokens[#tokens + 1] = "..."
			i += 3

			-- concat
		elseif source:sub(i, i+1) == ".." then
			tokens[#tokens + 1] = ".."
			i += 2
			-- comments
		elseif source:sub(i, i+1) == "--" then
			local start = i
			while i <= #source and source:sub(i, i) ~= "\n" do
				i += 1
			end
			tokens[#tokens + 1] = source:sub(start, i-1)

			-- strings
		elseif c == "\"" or c == "'" or c == "`" then
			local quote = c
			local start = i
			i += 1

			while i <= #source do
				local ch = source:sub(i, i)

				if ch == quote then
					local backslashCount = 0
					local j = i - 1

					while j >= start and source:sub(j, j) == "\\" do
						backslashCount += 1
						j -= 1
					end

					if backslashCount % 2 == 0 then
						i += 1
						break
					end
				end

				i += 1
			end

			tokens[#tokens + 1] = source:sub(start, i-1)

			-- :: operator
		elseif source:sub(i, i+1) == "::" then
			tokens[#tokens + 1] = "::"
			i += 2

			-- identifiers
		elseif c:match("[%a_]") then
			local start = i
			while i <= #source and source:sub(i, i):match("[%w_]") do
				i += 1
			end
			tokens[#tokens + 1] = source:sub(start, i-1)

			-- numbers
		elseif c:match("%d") then
			local start = i
			while i <= #source and source:sub(i, i):match("[%d%.]") do
				i += 1
			end
			tokens[#tokens + 1] = source:sub(start, i-1)

			-- operators
		else
			tokens[#tokens + 1] = c
			i += 1
		end
	end

	return tokens
end

local function highlightTokens(tokens: { string })
	local result = {}

	local typeDepth = 0
	local inType = false

	for i = 1, #tokens do
		local token = tokens[i]
		local color
		
		if token == "..." then
			result[#result + 1] = "..."
			continue
		end

		-- type mode
		if token == "::" then
			inType = true
			typeDepth = 0
			color = colors.operator

		elseif token == ":" then
			if not (tokens[i+1] and tokens[i+2] == "(") then
				inType = true
				typeDepth = 0
			end
			color = colors.operator
		elseif inType and typeDepth <= 0 then
			if token == "," or token == ")" or token == "=" or token == "\n" or token == ";" or luaSet[token] then
				inType = false
			end
		end

		if inType then
			if token == "{" or token == "(" or token == "<" then
				typeDepth += 1
			elseif token == "}" or token == ")" or token == ">" then
				typeDepth -= 1
			end

			local prevNonWs
			for j = i-1, 1, -1 do
				if not tokens[j]:match("^%s+$") then
					prevNonWs = tokens[j]
					break
				end
			end

			if token:match("^[%a_][%w_]*$") then
				if not (
					prevNonWs == ":" or
						prevNonWs == "::" or
						prevNonWs == "|" or
						prevNonWs == "&" or
						prevNonWs == "," or
						prevNonWs == "{" or
						prevNonWs == "<"
					) and typeDepth <= 0 then
					inType = false
				end
			end

			if inType then
				if token == "|" or token == "&" or token == "," then
					color = colors.operator
				elseif token:match("^[%a_][%w_]*$") then
					color = colors.type_annotation
				elseif operatorsSet[token] then
					color = colors.operator
				end
			end
		else
			if tonumber(token) then
				color = colors.numbers
			elseif token == "true" or token == "false" then
				color = colors.boolean
			elseif token == "nil" then
				color = colors.null
			elseif token == "self" then
				color = colors.self_color
			elseif token:sub(1,2) == "--" then
				color = colors.comment
			elseif token:sub(1,1) == "\"" or token:sub(1,1) == "'" or token:sub(1,1) == "`" then
				color = colors.str
			elseif luaSet[token] then
				color = colors.lua
			elseif rbxSet[token] or rbxclassSet[token] then
				color = colors.rbx
			elseif operatorsSet[token] then
				color = colors.operator
			end

			if tokens[i-1] == "." then
				local prev = tokens[i-2]

				if rbxclassSet[prev] then
					color = colors.rbx
				else
					if tokens[i+1] == "(" then
						color = colors.call
					else
						color = colors.local_property
					end
				end
			end

			if tokens[i+1] == "(" then
				if not (color or rbxSet[token] or rbxclassSet[token]) then
					if tokens[i-1] == ":" then
						color = colors.self_call
					else
						color = colors.call
					end
				end
			end
		end

		if color then
			local replacedText = token:gsub("<", "&lt;"):gsub(">", "&gt;")
			result[#result + 1] = string.format(
				"<font color=\"#%s\">%s</font>",
				color:ToHex(),
				replacedText
			)
		else
			result[#result + 1] = token
		end
	end

	return table.concat(result)
end

function highlighter.run(source: string)
	local tokens = tokenize(source)
	return highlightTokens(tokens)
end

return highlighter]]></ProtectedString>
			<string name="ScriptGuid">{D85E3FE5-3B69-430B-BB1E-B95B6AC9E4A7}</string>
